{
  "name": "leylines",
  "version": "0.2.1",
  "description": "Local scoped structured logs for applications and coding agents",
  "license": "MIT OR Apache-2.0",
  "author": "Alec Larson",
  "repository": {
    "type": "git",
    "url": "https://github.com/aleclarson/leylines.git"
  },
  "files": [
    "dist",
    "docs",
    "examples"
  ],
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "bin": {
    "ley": "./dist/cli.mjs",
    "leylines": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./cli": {
      "types": "./dist/cli.d.mts",
      "default": "./dist/cli.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.mts",
      "default": "./dist/browser.mjs"
    },
    "./vite": {
      "types": "./dist/vite.d.mts",
      "default": "./dist/vite.mjs"
    }
  },
  "scripts": {
    "dev": "tsdown --sourcemap --watch",
    "build": "tsdown",
    "format": "oxfmt .",
    "lint": "oxlint src",
    "typecheck": "tsc -p src/core --noEmit && tsc -p src/node --noEmit && tsc -p src/cli --noEmit && tsc -p src/browser --noEmit && tsc -p src/vite --noEmit && tsc -p src --noEmit && tsc -p test --noEmit",
    "test": "vitest",
    "prepublishOnly": "pnpm build",
    "sync-agent-rules": "curl -fsSL https://gist.githubusercontent.com/aleclarson/4c80686b1c3e204a01cdbe82f8e2c084/raw/AGENTS.md -o AGENTS.md && git add AGENTS.md && git commit -m 'chore: sync agent rules'"
  },
  "dependencies": {
    "cmd-ts": "^0.15.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "lildocs": "^0.1.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "radashi": "^12.9.1",
    "tsdown": "^0.22.3",
    "tsnapi": "^0.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.5.1"
}
