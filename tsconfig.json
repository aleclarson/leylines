{
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "strict": true,
    "erasableSyntaxOnly": true,
    "noUncheckedSideEffectImports": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "types": ["node"]
  }
}
